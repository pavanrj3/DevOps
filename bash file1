#Voting Eligibility Checker
votecheck() {
    read -p "Enter age: " age

    if [ "$age" -ge 18 ]; then
        echo "Eligible to vote"
    else
        echo "Not eligible to vote"
    fi
}
# Largest of Three Numbers
largest() {
    read -p "Enter three numbers: " a b c

    if [ "$a" -ge "$b" ] && [ "$a" -ge "$c" ]; then
        echo "$a is largest"
    elif [ "$b" -ge "$c" ]; then
        echo "$b is largest"
    else
        echo "$c is largest"
    fi
}
# Multiplication Table
table() {
    read -p "Enter a number: " n

    for i in {1..10}
    do
        echo "$n x $i = $((n*i))"
    done
}
# Factorial of a Number
factorial() {
    read -p "Enter a number: " n

    fact=1
    for ((i=1;i<=n;i++))
    do
        fact=$((fact*i))
    done

    echo "Factorial = $fact"
}
# Student Details
student() {
